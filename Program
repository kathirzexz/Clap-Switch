// 🔊 Clap Controlled Bulb using Arduino

int soundSensor = 2;    // KY-038 D0 pin connected to Arduino D2
int relayPin = 8;       // Relay IN pin connected to Arduino D8
bool bulbState = false; // Tracks bulb ON/OFF state
unsigned long lastTrigger = 0;
int debounceDelay = 200; // Prevents multiple triggers from one clap

void setup() {
  pinMode(soundSensor, INPUT);  // Sound sensor digital output
  pinMode(relayPin, OUTPUT);    // Relay module control pin
  digitalWrite(relayPin, LOW);  // Start with bulb OFF
  Serial.begin(9600);
  Serial.println("Clap Controlled Bulb Ready! 👏");
}

void loop() {
  int sensorValue = digitalRead(soundSensor); // Read sound signal

  if (sensorValue == HIGH && (millis() - lastTrigger > debounceDelay)) {
    bulbState = !bulbState;  // Toggle bulb state
    digitalWrite(relayPin, bulbState ? HIGH : LOW);
    Serial.println(bulbState ? "💡 Bulb ON" : "💤 Bulb OFF");
    lastTrigger = millis();  // Update last trigger time
  }
}
